<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUIVoorbeeld_NavigationPages.Paginas.XAML.HoofdpaginaXaml"
             Title="HoofdpaginaXaml">
    <VerticalStackLayout>
        <CollectionView ItemsSource="{Binding Pokémons}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button Text="{Binding Naam}" Clicked="Pokémon_Clicked" BindingContext="{Binding .}"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>